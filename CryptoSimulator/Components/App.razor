<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="CryptoSimulator - Virtual Cryptocurrency Trading Platform. Practice trading strategies with $10,000 virtual balance." />
    <title>CryptoSimulator — Virtual Crypto Trading</title>
    <base href="/" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="CryptoSimulator.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
    <script>
        // Apply saved theme before page renders to prevent flash
        (function () {
            var theme = localStorage.getItem('cs-theme') || 'dark';
            document.documentElement.setAttribute('data-bs-theme', theme);

            // MutationObserver to prevent Blazor Enhanced Navigation from stripping the theme
            var observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === 'data-bs-theme') {
                        var currentTheme = document.documentElement.getAttribute('data-bs-theme');
                        var savedTheme = localStorage.getItem('cs-theme') || 'dark';
                        if (currentTheme !== savedTheme) {
                            document.documentElement.setAttribute('data-bs-theme', savedTheme);
                        }
                    }
                });
            });
            observer.observe(document.documentElement, { attributes: true });
        })();
    </script>
</head>

<body>
    <Routes />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="_framework/blazor.web.js"></script>
    <script>
        function applyTheme() {
            var theme = localStorage.getItem('cs-theme') || 'dark';
            document.documentElement.setAttribute('data-bs-theme', theme);
            
            var btn = document.querySelector('#themeToggleBtn i');
            if (btn) {
                btn.className = theme === 'dark'
                    ? 'bi bi-sun-fill text-warning fs-6'
                    : 'bi bi-moon-stars-fill text-primary fs-6';
            }
        }

        // Sync toggle icon on page load
        document.addEventListener('DOMContentLoaded', applyTheme);

        // Sync theme and icon after Blazor enhanced navigation
        if (window.Blazor) {
            Blazor.addEventListener('enhancedload', applyTheme);
        }
    </script>
</body>

</html>
