@inherits LayoutComponentBase
@layout AccountLayout

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex align-items-center mb-4">
                <h2 class="gradient-text mb-0 fw-bold">
                    <i class="bi bi-person-gear me-2"></i>Manage Account
                </h2>
            </div>

            <div class="glass-card p-0 overflow-hidden">
                <div class="row g-0">
                    <div class="col-md-3 border-end border-secondary border-opacity-10 bg-dark bg-opacity-10 py-4">
                        <ManageNavMenu />
                    </div>
                    <div class="col-md-9 p-4 p-lg-5">
                        @Body
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
