@implements IDisposable

@inject NavigationManager NavigationManager

<nav class="navbar navbar-expand-lg border-bottom sticky-top cs-navbar">
    <div class="container">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="">
            <i class="bi bi-currency-bitcoin text-warning me-2 fs-4"></i>
            <span>CryptoSimulator</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
            aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-3 gap-1 fw-medium">
                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="dashboard">
                                <i class="bi bi-grid-1x2-fill me-1"></i> Dashboard
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="market">
                                <i class="bi bi-graph-up-arrow me-1"></i> Market
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="watchlist">
                                <i class="bi bi-star-fill text-warning me-1"></i> Watchlist
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="portfolio">
                                <i class="bi bi-wallet2 me-1"></i> Portfolio
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="leaderboard">
                                <i class="bi bi-trophy me-1"></i> Leaderboard
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="history">
                                <i class="bi bi-clock-history me-1"></i> History
                            </NavLink>
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                                <i class="bi bi-house-door me-1"></i> Home
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="market">
                                <i class="bi bi-graph-up-arrow me-1"></i> Market
                            </NavLink>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>
            </ul>
            <ul class="navbar-nav align-items-center gap-2">
                <!-- Theme Toggle -->
                <li class="nav-item">
                    <button id="themeToggleBtn"
                            class="btn btn-sm btn-outline-secondary rounded-circle p-1 d-flex align-items-center justify-content-center"
                            style="width:36px; height:36px;"
                            onclick="(function(){var t=document.documentElement.getAttribute('data-bs-theme')==='dark'?'light':'dark';document.documentElement.setAttribute('data-bs-theme',t);localStorage.setItem('cs-theme',t);var i=document.querySelector('#themeToggleBtn i');i.className=t==='dark'?'bi bi-sun-fill text-warning fs-6':'bi bi-moon-stars-fill text-primary fs-6';})()"
                            title="Toggle Dark/Light Mode">
                        <i class="bi bi-sun-fill text-warning fs-6"></i>
                    </button>
                </li>

                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item dropdown">
                            <a class="nav-link" href="#" role="button" data-bs-toggle="dropdown"
                                aria-expanded="false" title="Account Options">
                                <i class="bi bi-person-circle fs-5"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li>
                                    <div class="px-3 py-2 text-muted small text-truncate" style="max-width: 200px;">
                                        Signed in as<br />
                                        <strong class="text-body fw-bold">@context.User.Identity?.Name</strong>
                                    </div>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" href="Account/Manage"><i class="bi bi-gear me-2"></i>Manage Account</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form action="Account/Logout" method="post">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        <li class="nav-item">
                            <NavLink class="nav-link" href="Account/Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Login
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-warning btn-sm ms-2 my-1" href="Account/Register">
                                <i class="bi bi-person-plus me-1"></i> Register
                            </a>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
